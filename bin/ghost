#!/usr/bin/env bash
# ==============================================================================
# AMD Ghost Environment (Linux Consumer Edition v2.8 - Final Master)
# License: AGPL-3.0
# Author: ChrisGamer5013
# Description: A native Bash daemon that spoofs up to two AMD RDNA/Vega GPUs,
# injects the ZLUDA translation layer, and provides a Waiting Room TUI with DOOM.
# ==============================================================================

export LANG=en_US.UTF-8

GHOST_DIR="$HOME/.ghost"
ZLUDA_DIR="$GHOST_DIR/zluda"
DOOM_DIR="$GHOST_DIR/doom"
MUSIC_DIR="$GHOST_DIR/music"
CONFIG_DIR="$HOME/.config"
CONFIG_FILE="$CONFIG_DIR/ghost_env_setup"

# ANTI-NESTING LOCK
if [ "$GHOST_ENV_ACTIVE" == "1" ] && [[ "$*" != *"ghost-start"* ]]; then
    echo -e "\e[32m[GHOST] You are already inside the Ghost Environment.\e[0m"
    exit 0
fi

# ==============================================================================
# PHASE 1: DUAL-GPU DETECTION & JSON MAPPING
# ==============================================================================

detect_and_override_gpu() {
    local gpu_list=()
    
    for pci_path in /sys/bus/pci/devices/*; do
        if [ -f "$pci_path/vendor" ] && [ "$(cat "$pci_path/vendor")" == "0x1002" ]; then
            local class=$(cat "$pci_path/class" 2>/dev/null)
            if [[ "$class" == 0x030000 || "$class" == 0x030200 || "$class" == 0x038000 ]]; then
                local vram_bytes=0
                if [ -f "$pci_path/mem_info_vram_total" ]; then
                    vram_bytes=$(cat "$pci_path/mem_info_vram_total")
                fi
                
                # Filter out GPUs with < 2GB VRAM (iGPUs)
                if [ "$vram_bytes" -ge 2147483648 ]; then
                    local name=$(lspci -vnn -s $(basename $pci_path) | grep -iE 'vga|3d|display' | head -n 1)
                    
                    # FIX 1: VRAM UNIT CONVERSION (Bytes to GB)
                    local vram_gb=$(awk "BEGIN {printf \"%.1f\", $vram_bytes / 1073741824}")
                    
                    # FIX 2: DUAL-GPU "RENDER-NODE" MISMATCH (Extract exact ROCm index via renderD*)
                    local render_node=$(ls -1 "$pci_path/drm/" 2>/dev/null | grep -oP 'renderD\K\d+' | head -n 1)
                    local rocm_index=0
                    if [ -n "$render_node" ]; then
                        rocm_index=$((render_node - 128))
                    fi
                    
                    gpu_list+=("$vram_bytes|$rocm_index|$name|$vram_gb")
                fi
            fi
        fi
    done

    # Sort by VRAM descending and take top 2
    IFS=$'\n' sorted_gpus=($(sort -nr <<<"${gpu_list[*]}"))
    unset IFS

    local cluster_count=${#sorted_gpus[@]}
    [ $cluster_count -gt 2 ] && cluster_count=2

    local primary_name="UNKNOWN"
    local hip_devices="0"
    export GHOST_VRAM_GB="N/A"
    
    if [ $cluster_count -gt 0 ]; then
        primary_name=$(echo "${sorted_gpus[0]}" | cut -d'|' -f3)
        local idx1=$(echo "${sorted_gpus[0]}" | cut -d'|' -f2)
        export GHOST_VRAM_GB=$(echo "${sorted_gpus[0]}" | cut -d'|' -f4)
        hip_devices="$idx1"
        
        if [ $cluster_count -gt 1 ]; then
            local idx2=$(echo "${sorted_gpus[1]}" | cut -d'|' -f2)
            local vram2=$(echo "${sorted_gpus[1]}" | cut -d'|' -f4)
            export GHOST_VRAM_GB=$(awk "BEGIN {printf \"%.1f\", $GHOST_VRAM_GB + $vram2}")
            hip_devices="$idx1,$idx2"
        fi
    fi

    local series="UNKNOWN"

    if echo "$primary_name" | grep -qiE "(RX|Pro W)\s*(9|8|7|6|5)[0-9]{3}"; then
        series=$(echo "$primary_name" | grep -oP '(9|8|7|6|5)(?=[0-9]{3})' | head -1)"000"
    elif echo "$primary_name" | grep -qiE "Radeon\s*(8|7|6)[0-9]{2}M"; then
        series=$(echo "$primary_name" | grep -oP '(8|7|6)(?=[0-9]{2}M)' | head -1)"000"
    elif echo "$primary_name" | grep -qiE "MI50|Radeon\s*VII"; then
        series="MI50"
    elif echo "$primary_name" | grep -qiE "Vega\s*(56|64)"; then
        local v_num=$(echo "$primary_name" | grep -oP 'Vega\s*\K(56|64)' | head -1)
        series="VEGA$v_num"
    elif echo "$primary_name" | grep -qiE "Vega\s*Frontier"; then
        series="VEGA64"
    fi

    local mapping_file=""
    local script_path=$(readlink -f "${BASH_SOURCE[0]:-$0}" 2>/dev/null || realpath "${BASH_SOURCE[0]:-$0}" 2>/dev/null)
    local script_dir=$(dirname "$script_path" 2>/dev/null)
    
    local search_paths=(
        "$script_dir/../configs/mapping.json"
        "$script_dir/configs/mapping.json"
        "$PWD/configs/mapping.json"
        "$script_dir/../config/mapping.json"
        "$script_dir/config/mapping.json"
        "$PWD/config/mapping.json"
    )

    for path in "${search_paths[@]}"; do
        if [ -f "$path" ]; then
            mapping_file="$path"
            break
        fi
    done

    local gfx_mask="11.0.0"
    local spoof_name="Unknown AMD GPU (Spoofed)"

    if [ -n "$mapping_file" ] && [ -f "$mapping_file" ] && command -v python3 >/dev/null 2>&1; then
        local parsed=$(python3 -c '
import json, sys
try:
    with open(sys.argv[1], "r") as f: data = json.load(f)
    series = sys.argv[2]
    if series in data:
        print(f"{data[series].get(\"mask\", \"11.0.0\")}|{data[series].get(\"spoof\", \"Unknown AMD GPU (Spoofed)\")}")
        sys.exit(0)
    elif "DEFAULT" in data:
        print(f"{data[\"DEFAULT\"].get(\"mask\", \"11.0.0\")}|{data[\"DEFAULT\"].get(\"spoof\", \"Unknown AMD GPU (Spoofed)\")}")
        sys.exit(0)
except Exception:
    pass
print("11.0.0|Unknown AMD GPU (Spoofed)")
' "$mapping_file" "$series")
        
        if [ -n "$parsed" ]; then
            gfx_mask=$(echo "$parsed" | cut -d'|' -f1)
            spoof_name=$(echo "$parsed" | cut -d'|' -f2)
        fi
    fi

    if [ $cluster_count -gt 1 ]; then
        spoof_name="$spoof_name (Dual-GPU)"
        export GHOST_VRAM_GB="$GHOST_VRAM_GB GB (Dual)"
    else
        export GHOST_VRAM_GB="$GHOST_VRAM_GB GB"
    fi

    export HSA_OVERRIDE_GFX_VERSION="$gfx_mask"
    export HIP_VISIBLE_DEVICES="$hip_devices"
    export ROCR_VISIBLE_DEVICES="$hip_devices"
    export CUDA_VERSION="12.4"
    export NVIDIA_VISIBLE_DEVICES="all"
    export GHOST_SPOOF_NAME="$spoof_name"
    
    local series_num=7000
    [[ "$series" =~ ^[0-9]+$ ]] && series_num=$series
    if [ "$series_num" -ge 9000 ]; then
        export HSA_ENABLE_SDMA=0
    else
        export HSA_ENABLE_SDMA=1
    fi

    if [[ ":$PATH:" != *":$ZLUDA_DIR:"* ]]; then
        export PATH="$ZLUDA_DIR:$PATH"
    fi
}

# ==============================================================================
# PHASE 2: ZLUDA AUTO-INSTALLER & WIZARD
# ==============================================================================

install_zluda() {
    echo -e "\e[36m[GHOST] Downloading Linux ZLUDA Engine...\e[0m"
    rm -rf "$ZLUDA_DIR"
    mkdir -p "$ZLUDA_DIR"
    
    local tmp_tar="/tmp/zluda_latest_$$.tar.gz"
    local zluda_url=$(curl -s https://api.github.com/repos/lshqqytiger/ZLUDA/releases | grep -oP '"browser_download_url": "\K([^"]*linux[^"]*\.tar\.gz)(?=")' | head -n 1)
    [ -z "$zluda_url" ] && zluda_url="https://github.com/lshqqytiger/ZLUDA/releases/download/v3.0.0/ZLUDA-linux-amd64.tar.gz"

    if curl -f -L -# "$zluda_url" -o "$tmp_tar"; then
        if ! gzip -t "$tmp_tar" 2>/dev/null; then
            echo -e "\e[31m[GHOST] CRITICAL ERROR: Downloaded file is corrupted.\e[0m"
            rm -f "$tmp_tar"
            return 1
        fi

        echo -e "\e[36m[GHOST] Extracting ZLUDA...\e[0m"
        local tmp_ext="/tmp/zluda_ext_$$"
        mkdir -p "$tmp_ext"
        
        if tar -xzf "$tmp_tar" -C "$tmp_ext"; then
            local nested=$(find "$tmp_ext" -mindepth 1 -maxdepth 1 -type d | head -n 1)
            if [ -n "$nested" ]; then
                cp -a "$nested"/* "$ZLUDA_DIR/" 2>/dev/null
            else
                cp -a "$tmp_ext"/* "$ZLUDA_DIR/" 2>/dev/null
            fi
            rm -rf "$tmp_ext" "$tmp_tar"

            # FIX 3: ZLUDA PATH PERMISSIONS (Explicitly make binaries executable)
            chmod +x "$ZLUDA_DIR/zluda" 2>/dev/null
            chmod +x "$ZLUDA_DIR"/libcuda.so* 2>/dev/null

            if [ -f "$ZLUDA_DIR/libcuda.so" ] || [ -f "$ZLUDA_DIR/libcuda.so.1" ]; then
                echo -e "\e[32m[GHOST] ZLUDA installed successfully.\e[0m"
            else
                echo -e "\e[31m[GHOST] Warning: ZLUDA extracted, but core libraries are missing.\e[0m"
            fi
        else
            echo -e "\e[31m[GHOST] Error: Failed to extract ZLUDA archive.\e[0m"
            rm -rf "$tmp_ext" "$tmp_tar"
        fi
    else
        echo -e "\e[31m[GHOST] CRITICAL: ZLUDA download failed.\e[0m"
        rm -f "$tmp_tar"
    fi
}

first_startup_wizard() {
    mkdir -p "$CONFIG_DIR" "$ZLUDA_DIR" "$MUSIC_DIR"
    clear
    echo -e "\e[36m╔══════════════════════════════════════════════════════════╗\e[0m"
    echo -e "\e[36m║                 GHOST FIRST-STARTUP WIZARD               ║\e[0m"
    echo -e "\e[36m╚══════════════════════════════════════════════════════════╝\e[0m"
    echo -e "Welcome to Ghost. What tool are you initializing?"
    echo " (1) SwarmUI"
    echo " (2) SD.Next"
    echo " (3) Forge/A1111"
    echo " (4) vLLM/Custom"
    read -p "Select an option [1-4]: " choice

    local target_port=7860
    local patch_logic=""

    case "$choice" in
        1) target_port=7801; patch_logic="export TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1" ;;
        2) target_port=7860; patch_logic="export HSA_ENABLE_SDMA=0" ;;
        3) target_port=7860; patch_logic="export COMMANDLINE_ARGS='--opt-sdp-attention'" ;;
        4|*) target_port=8000; patch_logic="export GPU_MEMORY_UTILIZATION=0.90" ;;
    esac

    echo "export GHOST_TARGET_PORT=$target_port" > "$CONFIG_FILE"
    echo "$patch_logic" >> "$CONFIG_FILE"

    local zluda_lib=$(find "$ZLUDA_DIR" ! -type d \( -name "libcuda.so*" -o -name "*zluda*" \) 2>/dev/null | head -n 1)
    if [ -z "$zluda_lib" ]; then
        install_zluda
    fi

    echo -e "\e[32m[GHOST] Initialization complete.\e[0m"
    sleep 2
}

# ==============================================================================
# PHASE 3: MEDIA & DOOM (LINUX NATIVE)
# ==============================================================================

MUSIC_PID=""

stop_music() {
    if [ -n "$MUSIC_PID" ]; then
        kill -15 "$MUSIC_PID" 2>/dev/null
        MUSIC_PID=""
    fi
    pkill -15 -f "mpg123.*Ghost_" 2>/dev/null
}

toggle_music() {
    if ! command -v mpg123 >/dev/null 2>&1; then
        clear
        echo -e "\e[33m[GHOST] Audio player (mpg123) is missing. Auto-installing now...\e[0m"
        sudo apt-get update && sudo apt-get install -y mpg123
        if ! command -v mpg123 >/dev/null 2>&1; then
            echo -e "\e[31m[GHOST] Failed to install mpg123. Music disabled.\e[0m"
            sleep 3
            return
        fi
    fi

    if [ -n "$MUSIC_PID" ] && kill -0 "$MUSIC_PID" 2>/dev/null; then
        stop_music
    else
        mkdir -p "$MUSIC_DIR"
        local track="$MUSIC_DIR/Ghost_Track_4.mp3"
        
        if [ ! -f "$track" ] || [ $(stat -c%s "$track" 2>/dev/null || echo 0) -lt 100000 ]; then
            clear
            echo -e "\e[36m[GHOST] Downloading default music...\e[0m"
            curl -f -L -s "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-4.mp3" -o "$track"
        fi
        
        set +m
        mpg123 -q --loop -1 -b 1024 "$track" < /dev/null > /dev/null 2>&1 &
        MUSIC_PID=$!
        disown $MUSIC_PID 2>/dev/null
        set -m
    fi
}

launch_doom() {
    local doom_bin="$DOOM_DIR/doom-ascii"
    local doom_wad="$DOOM_DIR/DOOM1.WAD"
    local original_dir=$(pwd)
    local log_file=$1
    local config_port=$2

    if [ ! -x "$doom_bin" ]; then
        if ! command -v make >/dev/null 2>&1 || ! command -v gcc >/dev/null 2>&1 || ! dpkg -s libncurses-dev >/dev/null 2>&1; then
            clear
            echo -e "\e[33m[GHOST] DOOM dependencies missing. Auto-installing (make, gcc, libncurses)...\e[0m"
            sudo apt-get update && sudo apt-get install -y build-essential libncurses-dev
        fi

        clear
        echo -e "\e[33m[GHOST] Automating local DOOM installation...\e[0m"
        mkdir -p "$DOOM_DIR"
        cd "$DOOM_DIR" || return

        if [ ! -f "$doom_wad" ]; then
            echo -e "\e[36m[GHOST] Downloading DOOM Shareware WAD...\e[0m"
            curl -L -# "https://archive.org/download/2020_03_22_DOOM/DOOM%20WADs/DOOM1.WAD" -o DOOM1.WAD
        fi

        echo -e "\e[36m[GHOST] Compiling doom-ascii engine...\e[0m"
        rm -rf src
        git clone https://github.com/wojciech-graj/doom-ascii.git src
        cd src || return
        
        if ! make > make_error.log 2>&1; then
            clear
            echo -e "\e[31m[GHOST] DOOM Build failed!\e[0m"
            tail -n 10 make_error.log
            sleep 6
            cd "$original_dir"
            return
        fi
        
        local compiled_bin=$(find . -type f -name "doom-ascii" -executable | head -n 1)
        if [ -n "$compiled_bin" ]; then
            cp "$compiled_bin" "$doom_bin"
            chmod +x "$doom_bin"
            cd ..
            rm -rf src
            echo -e "\e[32m[GHOST] doom-ascii built successfully!\e[0m"
            sleep 1
        else
            cd "$original_dir"
            return
        fi
    fi

    cd "$DOOM_DIR" || return
    local launch_cmd="cd \"$DOOM_DIR\" && export LINES=35 COLUMNS=100 && ( while true; do if grep -qiE 'running on local url|uvicorn running on|starting web server|http://(127\.0\.0\.1|0\.0\.0\.0|localhost):[0-9]+' \"$log_file\" 2>/dev/null || ss -tulnp 2>/dev/null | grep -q \":$config_port \"; then killall -9 doom-ascii 2>/dev/null; exit; fi; sleep 1; done ) & exec \"$doom_bin\" -iwad \"$doom_wad\""
    
    if command -v gnome-terminal >/dev/null 2>&1; then
        gnome-terminal --full-screen -- bash -c "$launch_cmd"
    elif command -v xfce4-terminal >/dev/null 2>&1; then
        xfce4-terminal --fullscreen -e "bash -c '$launch_cmd'"
    elif command -v konsole >/dev/null 2>&1; then
        konsole --fullscreen -e bash -c "$launch_cmd"
    elif command -v xterm >/dev/null 2>&1; then
        xterm -fullscreen -e bash -c "$launch_cmd" &
    fi
    cd "$original_dir" || return
}

# ==============================================================================
# PHASE 4: THE WAITING ROOM TUI & SMART FAILOVER
# ==============================================================================

waiting_room() {
    local config_port=$1
    local app_pid=$2
    local mode_flag=$3
    local log_file=$4
    local dynamic_port=""
    local start_time=$(date +%s)

    pad_line() {
        local str="$1"
        local color="$2"
        local clean_str=$(echo "$str" | sed -r "s/\x1B\[[0-9;]*[a-zA-Z]//g")
        local pad_len=$(( 56 - ${#clean_str} ))
        [ $pad_len -lt 0 ] && pad_len=0
        local spaces=$(printf '%*s' "$pad_len" '')
        echo -e "\e[36m║  ${color}${str}${spaces}\e[36m║\e[0m"
    }

    local hw_file=$(mktemp)
    echo "N/A" > "$hw_file"
    
    set +m
    (
        while kill -0 "$app_pid" 2>/dev/null; do
            local rocm_out=$(rocm-smi --showtemp 2>/dev/null)
            local temp_raw=$(echo "$rocm_out" | grep -i "edge" | grep -oP '\d+\.\d+' | head -1)
            [ -z "$temp_raw" ] && temp_raw=$(echo "$rocm_out" | grep -oP '\d+\.\d+' | head -1)
            echo "${temp_raw:-N/A}" > "$hw_file"
            sleep 1
        done
    ) >/dev/null 2>&1 &
    local poller_pid=$!
    set -m

    tput civis

    while true; do
        if ! kill -0 "$app_pid" 2>/dev/null; then
            break
        fi

        dynamic_port=$(ss -tulnp 2>/dev/null | grep -E "pid=$app_pid\b" | awk '{print $5}' | rev | cut -d: -f1 | rev | grep -E '^[0-9]+$' | head -n 1)

        local log_ready=0
        if [ -f "$log_file" ] && grep -qiE "running on local url|uvicorn running on|starting web server|http://(127\.0\.0\.1|0\.0\.0\.0|localhost):[0-9]+" "$log_file"; then
            log_ready=1
        fi

        if [ -n "$dynamic_port" ] || [ "$log_ready" -eq 1 ] || ss -tulnp 2>/dev/null | grep -q ":$config_port "; then
            stop_music
            killall -9 doom-ascii 2>/dev/null
            pkill -9 -x doom-ascii 2>/dev/null
            tput cnorm
            clear
            break
        fi

        local current_time=$(date +%s)
        local elapsed=$((current_time - start_time))

        if [ $elapsed -gt 600 ]; then
            tput cnorm
            clear
            echo -e "\n\e[31m[GHOST] CRITICAL ERROR: AI Model failed to initialize within 10 minutes.\e[0m"
            echo -e "\e[33m[GHOST] Possible Shader Compilation Hang or Silent CUDA Error.\e[0m"
            kill -9 "$app_pid" 2>/dev/null
            break
        fi

        if [ $elapsed -gt 30 ]; then
            if [ ! -s "$log_file" ]; then
                tput cnorm
                clear
                echo -e "\n\e[31m[GHOST] CRITICAL ERROR: No output detected for 30 seconds.\e[0m"
                echo -e "\e[33m[GHOST] Possible Python shim conflict or silent crash.\e[0m"
                kill -9 "$app_pid" 2>/dev/null
                break
            fi
        fi

        read temp_val < "$hw_file"
        local temp="${temp_val}"
        local vram="${GHOST_VRAM_GB:-N/A}"

        local display_port="${dynamic_port:-$config_port (Wait)}"
        local status_str="STATUS: BOOTING AI MODEL / PORT: $display_port"
        [ ${#status_str} -gt 54 ] && status_str="${status_str:0:54}.."
        
        local short_spoof=$(echo "${GHOST_SPOOF_NAME:-RTX 4090}" | sed 's/NVIDIA GeForce //')
        local gpu_str="[ GPU: Spoofed as $short_spoof ]"
        local hw_combined="[ TEMP: ${temp}C ]             [ VRAM: ${vram} ]"

        local backend_str=""
        local backend_color="\e[36m"
        if [ "$mode_flag" == "ZLUDA" ]; then
            backend_str="[ BACKEND: Failover Detected -> ZLUDA Active ]"
            backend_color="\e[33m"
        else
            backend_str="[ BACKEND: ROCm Native -> Monitoring for failover ]"
        fi

        tput cup 0 0
        echo -e "\e[36m╔══════════════════════════════════════════════════════════╗\e[0m"
        echo -e "\e[36m║                 \e[32mGHOST ENVIRONMENT (v2.8)\e[36m                 ║\e[0m"
        echo -e "\e[36m╠══════════════════════════════════════════════════════════╣\e[0m"
        pad_line "$status_str" "\e[36m"
        pad_line "" "\e[36m"
        pad_line "$gpu_str" "\e[36m"
        pad_line "$hw_combined" "\e[36m"
        pad_line "$backend_str" "$backend_color"
        echo -e "\e[36m╠══════════════════════════════════════════════════════════╣\e[0m"
        echo -e "\e[36m║  HOTKEYS:                                                ║\e[0m"
        pad_line "[D] Play DOOM          [M] Toggle Music" "\e[36m"
        echo -e "\e[36m╚══════════════════════════════════════════════════════════╝\e[0m"

        read -t 0.5 -n 1 -s key
        case "$key" in
            m|M) toggle_music ;;
            d|D) launch_doom "$log_file" "$config_port" ;;
        esac
    done

    kill -9 "$poller_pid" 2>/dev/null
    rm -f "$hw_file"
    tput cnorm
}

# ==============================================================================
# PHASE 5: SMART EXECUTION LOGIC (ROCm Native -> ZLUDA Failover)
# ==============================================================================

run_with_failover() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo -e "\n\e[31m[GHOST] CRITICAL ERROR: Executable '$1' not found.\e[0m"
        echo -e "\e[33m[GHOST] Please verify it is installed and in your PATH.\e[0m"
        return 1
    fi

    local target_port=${GHOST_TARGET_PORT:-7860}
    local log_out="/tmp/ghost_ai_out_$$.log"
    local log_err="/tmp/ghost_ai_err_$$.log"
    local user_aborted=0

    rm -f "$log_out" "$log_err"

    trap 'user_aborted=1; stop_music; killall -9 doom-ascii 2>/dev/null; pkill -9 -x doom-ascii 2>/dev/null; kill -9 $app_pid 2>/dev/null' SIGINT

    echo -e "\e[36m[GHOST] Attempting Native Execution...\e[0m"

    "$@" > "$log_out" 2> "$log_err" &
    local app_pid=$!

    waiting_room "$target_port" "$app_pid" "ROCM" "$log_out"

    if [ $user_aborted -eq 1 ]; then
        echo -e "\n\e[33m[GHOST] Process aborted by user.\e[0m"
        rm -f "$log_out" "$log_err"
        trap - SIGINT
        return 130
    fi

    local needs_failover=0
    if ! kill -0 "$app_pid" 2>/dev/null; then
        wait "$app_pid" 2>/dev/null
        local exit_code=$?
        
        sleep 0.5
        
        if [ $exit_code -ne 0 ]; then
            if grep -qE "No HIP backend|CUDA out of memory|Torch not compiled with ROCm" "$log_err" "$log_out" 2>/dev/null; then
                needs_failover=1
            fi
        fi
    fi

    if [ $needs_failover -eq 1 ]; then
        rm -f "$log_out" "$log_err"

        local zluda_lib=$(find "$ZLUDA_DIR" ! -type d \( -name "libcuda.so*" -o -name "*zluda*" \) 2>/dev/null | head -n 1)
        if [ -z "$zluda_lib" ]; then
            install_zluda
            zluda_lib=$(find "$ZLUDA_DIR" ! -type d \( -name "libcuda.so*" -o -name "*zluda*" \) 2>/dev/null | head -n 1)
        fi

        if [ -n "$zluda_lib" ]; then
            local zluda_dir=$(dirname "$zluda_lib")
            
            LD_LIBRARY_PATH="$zluda_dir:$LD_LIBRARY_PATH" LD_PRELOAD="$zluda_lib" "$@" > "$log_out" 2> "$log_err" &
            app_pid=$!

            waiting_room "$target_port" "$app_pid" "ZLUDA" "$log_out"
            
            if [ $user_aborted -eq 1 ]; then
                echo -e "\n\e[33m[GHOST] Process aborted by user.\e[0m"
                rm -f "$log_out" "$log_err"
                trap - SIGINT
                return 130
            fi
        else
            clear
            echo -e "\e[31m[GHOST] CRITICAL: ZLUDA auto-repair failed. Cannot failover.\e[0m"
            [ -f "$log_err" ] && cat "$log_err"
            rm -f "$log_out" "$log_err"
            stop_music
            return 1
        fi
    fi

    clear
    [ -f "$log_out" ] && cat "$log_out"
    
    if kill -0 "$app_pid" 2>/dev/null; then
        tail -f "$log_out" "$log_err" 2>/dev/null &
        local tail_pid=$!
        
        trap 'kill -INT $app_pid 2>/dev/null' SIGINT
        wait "$app_pid" 2>/dev/null
        trap - SIGINT
        
        kill -9 "$tail_pid" 2>/dev/null
    fi

    wait "$app_pid" 2>/dev/null
    if [ $? -eq 0 ]; then
        rm -f "$log_out" "$log_err"
    else
        echo -e "\n\e[33m[GHOST] Process crashed. Full logs preserved at:\e[0m"
        echo -e "\e[90mOUT: $log_out\e[0m"
        echo -e "\e[90mERR: $log_err\e[0m"
    fi
    
    stop_music
}

# ==============================================================================
# MAIN EXECUTION BLOCK
# ==============================================================================

if [ "$1" == "--source-only" ]; then
    return 0 2>/dev/null || exit 0
fi

if [ "$1" == "install" ]; then
    echo -e "\e[36m[GHOST]\e[0m Installing Ghost Environment globally..."
    sudo ln -sf "$(realpath "$0")" /usr/local/bin/ghost
    echo -e "\e[32m[GHOST] Installation complete. Type 'ghost' to enter the sandbox.\e[0m"
    exit 0
fi

if [ -z "$GHOST_ENV_ACTIVE" ]; then
    echo -e "\e[36m[GHOST]\e[0m Initializing Virtual Environment..."

    if [ ! -f "$CONFIG_FILE" ]; then
        first_startup_wizard
    fi

    local script_path="$(realpath "$0")"
    local script_dir="$(dirname "$script_path")"
    local TMP_RC=$(mktemp)

    cat << EOF > "$TMP_RC"
[ -f ~/.bashrc ] && source ~/.bashrc
cd "$script_dir"

if [ -f "$script_dir/venv/bin/activate" ]; then
    source "$script_dir/venv/bin/activate"
    echo -e "\e[32m[GHOST] Python Venv Activated: \$VIRTUAL_ENV\e[0m"
elif [ -f "\$PWD/venv/bin/activate" ]; then
    source "\$PWD/venv/bin/activate"
elif [ -f "\$HOME/venv/bin/activate" ]; then
    source "\$HOME/venv/bin/activate"
fi

source "$script_path" --source-only
detect_and_override_gpu
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"

export GHOST_ENV_ACTIVE=1
export PS1="\[\e[32m\](ghost-env)\[\e[0m\] \u@\h:\w$ "

ghost-start() {
    run_with_failover "\$@"
}
export -f ghost-start

echo -e "\e[32m[GHOST] Environment Active. GPU Spoofed. GFX Masked via JSON.\e[0m"
echo -e "\e[36m[GHOST] -> To run your AI with failover, type: \e[1mghost-start python3 your_script.py\e[0m"
EOF

    bash --rcfile "$TMP_RC"
    rm -f "$TMP_RC"
else
    if [ $# -gt 0 ]; then
        "$@"
    else
        echo -e "\e[32m[GHOST] You are already inside the Ghost Environment.\e[0m"
    fi
fi
